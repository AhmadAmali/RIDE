# Database
DATABASE_URL=postgresql+asyncpg://ride:ride@postgres:5432/ride
POSTGRES_USER=ride
POSTGRES_PASSWORD=ride
POSTGRES_DB=ride

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# API
CORS_ORIGINS=["http://localhost:3000"]
API_HOST=0.0.0.0
API_PORT=8000

# Anthropic / Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# File uploads
UPLOAD_DIR=/uploads
MAX_UPLOAD_BYTES=52428800
